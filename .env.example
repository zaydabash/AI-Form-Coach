# FormIQ environment configuration. Copy to .env and fill in.

# Required: API key for the coaching model provider
LLM_API_KEY=

# Required: model ids (fast model scored per rep, deeper model for the summary)
FORMIQ_REP_MODEL=
FORMIQ_SUMMARY_MODEL=

# Optional: text-to-speech key for spoken feedback (silent if unset)
DEEPGRAM_API_KEY=

# Optional: shared access passcode for the cloud API gate (empty = open)
FORMIQ_ACCESS_CODE=

# Optional tuning
DEEPGRAM_TTS_MODEL=aura-asteria-en
FORMIQ_WEBCAM_INDEX=0
FORMIQ_TARGET_FPS=15
FORMIQ_COACH_IMG_MAX_EDGE=512
