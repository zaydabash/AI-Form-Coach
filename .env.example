# FormIQ environment configuration — copy to .env and fill in.

# Required: Claude Opus 4.8 coaching brain
ANTHROPIC_API_KEY=sk-ant-...

# Required for spoken feedback (optional — backend runs silently without it)
DEEPGRAM_API_KEY=...

# Optional: Arize Phoenix collector. Defaults to a local Phoenix instance.
# Run `phoenix serve` and open http://localhost:6006 to view traces.
ARIZE_PHOENIX_ENDPOINT=http://localhost:6006

# Model strategy (hybrid): fast Haiku per rep (sub-2s), deep Opus for summary
FORMIQ_REP_MODEL=claude-haiku-4-5
FORMIQ_SUMMARY_MODEL=claude-opus-4-8

# Optional overrides
DEEPGRAM_TTS_MODEL=aura-asteria-en
FORMIQ_WEBCAM_INDEX=0
FORMIQ_TARGET_FPS=15
FORMIQ_JPEG_QUALITY=80
# Coaching image is downscaled to this long-edge px before the vision call
FORMIQ_COACH_IMG_MAX_EDGE=512
